<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xsi:type="MailApp">
  <Id>3DEE1D77-2E66-4076-827C-253138DC776D</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>CEF Srl</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="CEF mail"/>
  <Description DefaultValue="Genera bozze email CEF con AI"/>
  <IconUrl DefaultValue="https://project-qyb4m.vercel.app/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://project-qyb4m.vercel.app/icon-128.png"/>
  <SupportUrl DefaultValue="https://project-qyb4m.vercel.app"/>
  <AppDomains>
    <AppDomain>project-qyb4m.vercel.app</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://project-qyb4m.vercel.app/taskpane.html"/>
        <RequestedHeight>550</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
                    xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Cmd"/>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="grp1">
                <Label resid="grpLabel"/>
                <Control xsi:type="Button" id="btn1">
                  <Label resid="btnLabel"/>
                  <Supertip>
                    <Title resid="btnLabel"/>
                    <Description resid="btnTip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16"/>
                    <bt:Image size="32" resid="icon32"/>
                    <bt:Image size="80" resid="icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>tp1</TaskpaneId>
                    <SourceLocation resid="tpUrl"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://project-qyb4m.vercel.app/icon-16.png"/>
        <bt:Image id="icon32" DefaultValue="https://project-qyb4m.vercel.app/icon-32.png"/>
        <bt:Image id="icon80" DefaultValue="https://project-qyb4m.vercel.app/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Cmd" DefaultValue="https://project-qyb4m.vercel.app/commands.html"/>
        <bt:Url id="tpUrl" DefaultValue="https://project-qyb4m.vercel.app/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="grpLabel" DefaultValue="CEF mail"/>
        <bt:String id="btnLabel" DefaultValue="CEF mail"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="btnTip" DefaultValue="Genera bozza risposta con AI"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
